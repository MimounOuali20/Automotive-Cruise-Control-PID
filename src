%% 02_plot_results.m - Professional Graphics for LinkedIn
% Ce script utilise les données exportées par le bloc "Visualization & Data Logging"

% Vérification si les données existent (gestion du préfixe 'out.')
if exist('out','var')
    s = out;
else
    s = struct('ref_logged', ref_logged, 'actual_logged', actual_logged, ...
               'error_logged', error_logged, 'force_logged', force_logged, ...
               'grade_logged', grade_logged, 'aero_logged', aero_logged, ...
               'grade_force_logged', grade_force_logged);
end

% 1. PERFORMANCE DE SUIVI DE VITESSE
figure('Color', 'w', 'Position', [100 100 800 500]);
plot(s.ref_logged.Time, s.ref_logged.Data, 'k--', 'LineWidth', 2); hold on;
plot(s.actual_logged.Time, s.actual_logged.Data, 'Color', [0 0.447 0.741], 'LineWidth', 2.5);
grid on;
xlabel('Temps (s)'); ylabel('Vitesse (km/h)');
title('Performance du Régulateur de Vitesse (PID)');
